# Exception chaining
令 链式异常 = 假
尝试:
    尝试:
        抛出 ValueError("v")
    除了 ValueError 作为 ve:
        抛出 RuntimeError("r") 从 ve
除了 RuntimeError:
    链式异常 = 真

# Multiple 除了 handlers
令 多异常值 = 0
尝试:
    抛出 TypeError("t")
除了 ValueError:
    多异常值 = 1
除了 TypeError:
    多异常值 = 2

# Match/情况 使用 默认
令 匹配值 = 2
令 匹配结果 = "other"
匹配 匹配值:
    情况 1:
        匹配结果 = "one"
    情况 2:
        匹配结果 = "two"
    默认:
        匹配结果 = "默认"

# Decorator
函数 加倍器(func):
    函数 包装器(*参数, **命名参数):
        返回 func(*参数, **命名参数) * 2
    返回 包装器

@加倍器
函数 十():
    返回 10

令 装饰结果 = 十()

# Multiple inheritance, static/类 methods, property
类 混入类:
    函数 混合(self):
        返回 1

类 基类二:
    函数 __init__(self, start):
        self.value = start

类 组合类(基类二, 混入类):
    @staticmethod
    函数 标签():
        返回 "combined"
    @classmethod
    函数 构建(cls, v):
        返回 cls(v)
    @property
    函数 双倍属性(self):
        返回 self.value * 2

令 组合对象 = 组合类.构建(3)
令 属性值 = 组合对象.双倍属性

