# async def, await, async for, async with (v0.6.0)
async 函数 异步双倍(n):
    await asyncio.sleep(0)
    返回 n * 2

async 函数 异步生成_中():
    对于 v 里 range(3):
        产出 v

async 函数 异步循环任务():
    令 异步总计 = 0
    async 对于 av 里 异步生成_中():
        异步总计 = 异步总计 + av
    返回 异步总计

类 异步上下文中:
    async 函数 __aenter__(self):
        返回 5
    async 函数 __aexit__(self, exc_type, exc, tb):
        返回 假

async 函数 异步使用任务():
    async 使用 异步上下文中() 作为 值:
        返回 值

令 异步结果 = asyncio.run(异步双倍(5))
令 异步循环结果 = asyncio.run(异步循环任务())
令 异步使用结果 = asyncio.run(异步使用任务())

