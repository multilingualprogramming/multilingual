# 試行/例外/でなければ
変数 試行それ以外 = 0
試行:
    試行それ以外 = 整数("7")
例外 ValueError:
    試行それ以外 = -1
でなければ:
    試行それ以外 += 1

# Exception chaining
変数 連鎖例外 = 偽
試行:
    試行:
        発生 ValueError("v")
    例外 ValueError として ve:
        発生 RuntimeError("r") から ve
例外 RuntimeError:
    連鎖例外 = 真

# Multiple 例外 handlers
変数 複数例外 = 0
試行:
    発生 TypeError("t")
例外 ValueError:
    複数例外 = 1
例外 TypeError:
    複数例外 = 2

# Match/場合 付き 既定
変数 一致値 = 2
変数 一致結果 = "other"
照合 一致値:
    場合 1:
        一致結果 = "one"
    場合 2:
        一致結果 = "two"
    既定:
        一致結果 = "既定"

# Decorator
関数 倍化器(func):
    関数 包み(*引数列, **名前付き引数):
        戻る func(*引数列, **名前付き引数) * 2
    戻る 包み

@倍化器
関数 十():
    戻る 10

変数 装飾結果 = 十()

# Multiple inheritance, static/クラス methods, property
クラス 混合クラス:
    関数 混合(self):
        戻る 1

クラス 基底二:
    関数 __init__(self, start):
        self.value = start

クラス 結合クラス(基底二, 混合クラス):
    @staticmethod
    関数 ラベル():
        戻る "combined"
    @classmethod
    関数 構築(cls, v):
        戻る cls(v)
    @property
    関数 倍化属性(self):
        戻る self.value * 2

変数 結合オブジェクト = 結合クラス.構築(3)
変数 属性値 = 結合オブジェクト.倍化属性

