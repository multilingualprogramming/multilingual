# Async Concurrency Keywords (v0.8.0) - SPAWN, CHANNEL, SEND, RECEIVE
変数 spawn_channel = チャネル()

async 関数 spawn_test_async():
    async 関数 task_worker(value):
        await asyncio.sleep(0)
        戻る value * 2

    変数 spawn_task = 起動(task_worker(5))
    戻る "spawn task created"

変数 spawn_result = asyncio.run(spawn_test_async())
表示("Async concurrency keywords validated:", spawn_result)

# Reactive UI Keywords (v0.8.0) - OBSERVE, ON_CHANGE
関数 test_reactive_ui() 使う ui:
    観測 var counter_value = 0
    観測 var status_text = "ready"

    変更時 counter_value.change:
        表示("Counter value changed")

    変更時 status_text.change:
        表示("Status changed")

    表示("Reactive UI keywords validated")

test_reactive_ui()

