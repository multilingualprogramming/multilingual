# async def, await, async for, async with (v0.6.0)
async 関数 非同期二倍(n):
    await asyncio.sleep(0)
    戻る n * 2

async 関数 非同期生成_日():
    毎 v 中 range(3):
        生成 v

async 関数 非同期ループ処理():
    変数 非同期合計 = 0
    async 毎 av 中 非同期生成_日():
        非同期合計 = 非同期合計 + av
    戻る 非同期合計

クラス 非同期コンテキスト日:
    async 関数 __aenter__(self):
        戻る 5
    async 関数 __aexit__(self, exc_type, exc, tb):
        戻る 偽

async 関数 非同期付き処理():
    async 付き 非同期コンテキスト日() として 値:
        戻る 値

変数 非同期結果 = asyncio.run(非同期二倍(5))
変数 非同期ループ結果 = asyncio.run(非同期ループ処理())
変数 非同期付き結果 = asyncio.run(非同期付き処理())

