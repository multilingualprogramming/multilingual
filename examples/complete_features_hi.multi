# समवर्ती कीवर्ड (v0.7.0) - समानांतर, चैनल, शुरुआत
परिभाषा जोड़ें_संख्याएं(x, y):
    वापसी x + y

परिभाषा गुणा_संख्याएं(x, y):
    वापसी x * y

मान par_a, par_b = समानांतर [
    जोड़ें_संख्याएं(5, 3),
    गुणा_संख्याएं(4, 2)
]
प्रिंट("समानांतर परिणाम:", par_a, par_b)

