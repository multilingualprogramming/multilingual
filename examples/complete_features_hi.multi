# Async Concurrency Keywords (v0.8.0) - SPAWN, CHANNEL, SEND, RECEIVE
मान spawn_channel = चैनल()

asink परिभाषा spawn_test_async():
    asink परिभाषा task_worker(value):
        pratiksha asyncio.sleep(0)
        वापसी value * 2

    मान spawn_task = प्रारंभ(task_worker(5))
    वापसी "spawn task created"

मान spawn_result = asyncio.run(spawn_test_async())
प्रिंट("Async concurrency keywords validated:", spawn_result)

# Reactive UI Keywords (v0.8.0) - OBSERVE, ON_CHANGE
परिभाषा test_reactive_ui() उपयोग ui:
    देखो var counter_value = 0
    देखो var status_text = "ready"

    परिवर्तन_पर counter_value.change:
        छापो("Counter value changed")

    परिवर्तन_पर status_text.change:
        छापो("Status changed")

    छापो("Reactive UI keywords validated")

test_reactive_ui()

