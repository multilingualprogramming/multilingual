# Core 1.0 Edge Computing with Local Ollama Models — English
# Demonstrates: @local placement, @llama3/@magistral/@gemma3 model refs,
#               par[...] parallel inference, memory(...) caching,
#               trace/cost observability, @swarm with local agents

# Setup: Register OllamaProvider to connect to local Ollama instance
from multilingualprogramming.runtime.ai_runtime import AIRuntime
from multilingualprogramming.runtime.ollama_provider import OllamaProvider
AIRuntime.register(OllamaProvider())

# ── Placement: @local signals compute stays on-device ────────────────────────
@local
fn analyze_sensor_reading(reading: str) -> str uses ai:
    let analysis = prompt @llama3:
        "Analyze temperature: 85C, humidity: 92%, pressure: 995mb. Are these normal or anomalous?"
    return analysis

@local
fn classify_device_status(data: str) -> str uses ai:
    let status = prompt @llama3:
        "Is a device with CPU 95%, Memory 88%, Disk 72% healthy or overloaded?"
    return status

@local
fn generate_alert(issue: str) -> str uses ai:
    let alert = prompt @llama3:
        "Create a one-sentence alert for high temperature and humidity readings."
    return alert

# ── Parallel inference: multiple models in parallel ──────────────────────────
fn multi_model_analysis(sensor_data: str) -> str uses ai:
    let analysis, classification, alert = par [
        prompt @llama3: "Analyze: " + sensor_data,
        classify @gemma3: sensor_data,
        generate @llama3: "Alert for: " + sensor_data
    ]
    let summary = prompt @llama3:
        "Synthesise these results:\n"
        + "Analysis: " + analysis + "\n"
        + "Status: " + classification + "\n"
        + "Alert: " + alert
    return summary

# ── Caching: local memory for inference results ──────────────────────────────
fn cached_analysis(query: str) -> str uses ai:
    let cache = memory("analysis_cache", scope="session")

    if query in cache:
        return cache[query]

    let result = prompt @llama3: "Analyze: " + query
    cache[query] = result
    return result

# ── Cost tracking with local models ──────────────────────────────────────────
fn traced_inference(query: str) -> str uses ai:
    let result_with_cost = cost(prompt @llama3: query)
    let result, spend = result_with_cost

    print("Local inference cost (estimated tokens):", spend)
    return result

# ── Parallel analysis: demonstrates par[...] executing tasks concurrently
fn edge_analytics_team(input_data: str) -> str uses ai:
    # Run three analysis tasks in parallel (key feature: par[...])
    let diag1, diag2, diag3 = par [
        prompt @llama3: "Is this device healthy? " + input_data,
        prompt @llama3: "What is the main performance issue? " + input_data,
        prompt @llama3: "What action should be taken? " + input_data
    ]

    # Combine parallel results into summary
    let summary = "Device Health: " + diag1 + " | Issue: " + diag2 + " | Action: " + diag3
    return summary

# ── Main: demonstrate edge computing patterns ────────────────────────────────
fn main() uses ai:
    print("━━━ Edge Computing Pipeline Starting ━━━")

    # Test 1: Local sensor analysis
    print("\n→ Test 1: Sensor analysis on edge device...")
    let analysis = analyze_sensor_reading("sensor data")
    print("✓ Analysis:", analysis)

    # Test 2: Memory/caching for repeated queries
    let query = "What is edge computing?"
    print("\n→ Test 2: Query with local caching (first run)...")
    let cached = cached_analysis(query)
    print("✓ Cached (showing first 200 chars):", cached)

    # Test 3: Parallel analysis using par[...] - demonstrates concurrent execution
    print("\n→ Test 3: Parallel multi-analysis on device status...")
    let status = "CPU: 95%, Memory: 88%, Disk: 72%"
    let team_result = edge_analytics_team(status)
    print("✓ Parallel analysis complete:")
    print(team_result)

    print("\n━━━ Pipeline Complete ━━━")

main()
