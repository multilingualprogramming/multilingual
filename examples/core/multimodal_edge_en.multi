# Core 1.0 Multimodal Edge Computing - English
# Demonstrates: image analysis at the edge with @local placement,
#               multimodal prompts with vision models,
#               document processing pipelines,
#               inference caching for visual results

# Setup: Register OllamaProvider to connect to local Ollama instance
from multilingualprogramming.runtime.ai_runtime import AIRuntime
from multilingualprogramming.runtime.ollama_provider import OllamaProvider
AIRuntime.register(OllamaProvider(max_tokens=256))

fn vision_query(media, instruction) -> str uses ai:
    let request = MultimodalPrompt().add_text(instruction).add(media)
    return prompt @llama3.2-vision: request

# -- Image analysis at the edge -----------------------------------------------
@local
fn analyze_image(photo) -> str uses ai:
    return vision_query(photo, "Describe this image in one concise sentence.")

@local
fn classify_scene(photo) -> str uses ai:
    return vision_query(photo, "Classify the scene in five words or fewer.")

@local
fn detect_objects(photo) -> str uses ai:
    return vision_query(photo, "List the main visible objects only.")

# -- Document processing: OCR + extraction at the edge ------------------------
@local
fn extract_from_document(doc) -> str uses ai:
    return vision_query(doc, "Extract the visible text exactly.")

@local
fn extract_invoice_items(invoice_doc) -> str uses ai:
    return vision_query(invoice_doc, "Extract invoice items as a short list.")

# -- Parallel multimodal analysis ---------------------------------------------
fn multi_analysis(photo) -> str uses ai:
    let analysis, scene, objects = par [
        vision_query(photo, "Describe this image in one concise sentence."),
        vision_query(photo, "Classify the scene in five words or fewer."),
        vision_query(photo, "List the main clear and visible objects only.")
    ]
    let summary = prompt @llama3: "Summarize: " + analysis + " " + scene + " " + objects
    return summary

# -- Caching multimodal results for repeated queries --------------------------
fn cached_analysis(photo) -> str uses ai:
    let cache = memory("image_analysis_cache", scope="session")
    let photo_key = "flower_jpg"

    if photo_key in cache:
        return cache[photo_key]

    let result = vision_query(photo, "Describe this image in one concise sentence.")
    cache[photo_key] = result
    return result

# -- Cost-aware multimodal inference ------------------------------------------
fn cost_tracked_analysis(photo) -> str uses ai:
    let with_cost = cost(vision_query(photo, "Describe this image in one concise sentence."))
    let result, expense = with_cost
    print("Inference cost (tokens):", expense)
    return result

# -- Multi-modal swarm: specialized agents for different modalities -----------
@local
@agent(model=@llama3.2-vision)
fn image_analyst(photo) -> str uses ai:
    return vision_query(photo, "Describe this image in one concise sentence.")

@local
@agent(model=@llama3.2-vision)
fn scene_classifier(photo) -> str uses ai:
    return vision_query(photo, "Classify the scene in five words or fewer.")

@local
@agent(model=@llama3.2-vision)
fn document_extractor(doc) -> str uses ai:
    return vision_query(doc, "Extract the visible text exactly.")

@swarm(agents=[image_analyst, scene_classifier, document_extractor])
fn media_analysis_team(media_input) -> str uses ai:
    let cache = memory("media_team_results", scope="session")
    let media_key = "media_analysis"

    if media_key in cache:
        return cache[media_key]

    let image_analysis = delegate(image_analyst, media_input)
    let scene = delegate(scene_classifier, media_input)
    let extracted = delegate(document_extractor, media_input)

    let final = prompt @llama3: "Combine: " + image_analysis + " " + scene + " " + extracted

    cache[media_key] = final
    return final

# -- Main: quick multimodal edge demo -----------------------------------------
fn main() uses ai:
    print("=== Multimodal Edge Computing ===")

    let photo_data = ImageValue.from_path("examples/flower.jpg", mime_type="image/jpeg")

    print("")
    print("-> Test 1: Analyzing image with vision model...")
    let analyzed = analyze_image(photo_data)
    print("OK Image analysis:", analyzed)

    print("")
    print("-> Test 2: Cached analysis...")
    let cached = cached_analysis(photo_data)
    print("OK Cached result:", cached)

    print("")
    print("-> Test 3: Scene classification...")
    let classified = classify_scene(photo_data)
    print("OK Scene classification:", classified)

    print("")
    print("-> Test 4: Object detection...")
    let objects = detect_objects(photo_data)
    print("OK Objects detected:", objects)

    print("")
    print("-> Test 5: Parallel multimodal analysis...")
    let combined = multi_analysis(photo_data)
    print("OK Combined analysis:", combined)

    print("")
    print("-> Test 6: Swarm media analysis team...")
    let team_result = media_analysis_team(photo_data)
    print("OK Team analysis:", team_result)

    print("")
    print("=== Multimodal Processing Complete ===")

main()
