ধরি একীভূত_মানচিত্র = {**{"x": 1}, **{"y": 2}}

সংজ্ঞা ট্যাগ_বিন্যাস(a, /, *, b):
    ফেরত f"{a}-{b:.1f}"

ধরি লেবেল_ফর্ম্যাট = ট্যাগ_বিন্যাস(7, b=3.5)
ধরি বীজ = 0
ধরি মোচ_মূল্য = (বীজ := বীজ + 9)

শ্রেণি গণক_বাক্স:
    সংজ্ঞা __init__(self, শুরু_ভিত্তি):
        self.মূল্য = শুরু_ভিত্তি

শ্রেণি গণক_বাক্স_শিশু(গণক_বাক্স):
    সংজ্ঞা __init__(self, শুরু_ভিত্তি):
        সুপার(গণক_বাক্স_শিশু, self).__init__(শুরু_ভিত্তি)
        self.মূল্য = self.মূল্য + 1

সংজ্ঞা উৎপাদন_তিন():
    জন্য সূচক মধ্যে পরিসর(3):
        উৎপন্ন সূচক

ধরি মোট_উৎপন্ন = যোগফল(উৎপাদন_তিন())
ধরি পরিচালনা = মিথ্যা

চেষ্টা:
    যদি দৈর্ঘ্য(অনন্য_মূল্য) > 2:
        তোলো ValueError("boom")
ব্যতিক্রম ValueError হিসাবে পরিচালিত_ত্রুটি:
    পরিচালনা = সত্য
অবশেষে:
    ধরি মূল_মূল্য = পূর্ণসংখ্যা(মূল_ফাংশন(16))

ধরি অস্থায়ী_মূল্য = 99
মুছো অস্থায়ী_মূল্য

ধরি লুপ_সংগ্রহ = 0
জন্য n মধ্যে পরিসর(6):
    যদি n == 0:
        ছাড়ো
    যদি n == 4:
        থামো
    যদি n % 2 == 0:
        চালাও
    লুপ_সংগ্রহ = লুপ_সংগ্রহ + n

ধরি পতাকা_ঠিক = সত্য এবং না মিথ্যা
নিশ্চিত পতাকা_ঠিক

ধরি শিশু_বাক্স = গণক_বাক্স_শিশু(40)

ছাপাও(বৃদ্ধি_বৈশ্বিক())
ছাপাও(প্রথম_ধাপ, দ্বিতীয়_ধাপ)
ছাপাও(ফাইল_পাঠ্য)
ছাপাও(দৈর্ঘ্য(যুক্ত_জোড়), দৈর্ঘ্য(অনন্য_মূল্য), স্থির_মূল্য[1])
ছাপাও(প্রথম_উপাদান, মধ্য_উপাদান, শেষ_উপাদান)
ছাপাও(শিশু_বাক্স.মূল্য)
ছাপাও(মোট_উৎপন্ন, মূল_মূল্য, পরিচালনা)
ছাপাও(একীভূত_মানচিত্র["x"] + একীভূত_মানচিত্র["y"], লেবেল_ফর্ম্যাট, মোচ_মূল্য)
ছাপাও(লুপ_সংগ্রহ)
ছাপাও(ভাগ_করা_গণক হলো কিছুনা)

# Loop else clauses
ধরি উপাদান_পাওয়া = মিথ্যা
জন্য উপাদান মধ্যে পরিসর(3):
    যদি উপাদান == 10:
        উপাদান_পাওয়া = সত্য
        থামো
নাহলে:
    উপাদান_পাওয়া = "not_found"

ধরি যখন_অন্যথা_val = 0
যতক্ষণ যখন_অন্যথা_val < 2:
    যখন_অন্যথা_val = যখন_অন্যথা_val + 1
নাহলে:
    যখন_অন্যথা_val = যখন_অন্যথা_val + 10

# Starred unpacking variations
ধরি a, *বাকি = [10, 20, 30, 40]
ধরি *init, b = [10, 20, 30, 40]
ধরি c, *মধ্য, d = [10, 20, 30, 40]

# Set comprehension
ধরি বর্গ_সেট = {x * x জন্য x মধ্যে পরিসর(5)}

# Extended builtins
ধরি শক্তি_ফলাফল = ঘাত(2, 8)
ধরি divmod_ফলাফল = ভাগশেষ(17, 5)

# Yield from generator
সংজ্ঞা প্রতিনিধি_জেন():
    উৎপন্ন থেকে পরিসর(3)

ধরি প্রতিনিধিত্ব = তালিকা(প্রতিনিধি_জেন())

ছাপাও(উপাদান_পাওয়া, যখন_অন্যথা_val)
ছাপাও(a, বাকি, init, b, c, মধ্য, d)
ছাপাও(সাজানো(বর্গ_সেট))
ছাপাও(শক্তি_ফলাফল, divmod_ফলাফল)
ছাপাও(প্রতিনিধিত্ব)

# Numeric literals
ধরি হেক্স_সংখ্যা = 0xFF
ধরি অক্ট_সংখ্যা = 0o17
ধরি বাইনারি_সংখ্যা = 0b1010
ধরি বৈজ্ঞানিক_সংখ্যা = 1.5e3

# Augmented assignments
ধরি বর্ধিত = 10
বর্ধিত += 5
বর্ধিত -= 2
বর্ধিত *= 3
বর্ধিত //= 4
বর্ধিত %= 3

# Bitwise operators
ধরি বিট_এবং = 0b1010 & 0b1100
ধরি বিট_অথবা = 0b1010 | 0b0101
ধরি বিট_এক্স = 0b1010 ^ 0b1111
ধরি বিট_বাম = 1 << 3
ধরি বিট_ডান = 64 >> 2

# Chained assignment
ধরি শৃঙ্খল_ক = শৃঙ্খল_খ = শৃঙ্খল_গ = 0

# Type annotations
ধরি টাইপিত: পূর্ণসংখ্যা = 99

সংজ্ঞা টীকাযুক্ত(x: পূর্ণসংখ্যা, y: float) -> পাঠ্য:
    ফেরত পাঠ্য(x + y)

# Ternary expression
ধরি ত্রিমুখী = "yes" যদি টাইপিত > 0 নাহলে "no"

# Default params, *args, **kwargs
সংজ্ঞা বহু_প্যারাম(ভিত্তি, অতিরিক্ত=1, *আর্গস, **নামযুক্ত_আর্গস):
    ফেরত ভিত্তি + অতিরিক্ত + যোগফল(আর্গস)
ধরি বহু_ফল = বহু_প্যারাম(10, 2, 3, 4, চাবি=5)

# Lambda
ধরি বর্গ = ল্যাম্বডা x: x * x

# List/dict comprehensions এবং generator expression
ধরি তালিকা_সি = [x * 2 জন্য x মধ্যে পরিসর(4)]
ধরি অভিধান_সি = {পাঠ্য(k): k * k জন্য k মধ্যে পরিসর(3)}
ধরি জেনারেটর_সি = তালিকা(x + 1 জন্য x মধ্যে পরিসর(3))
ধরি নেস্টেড_সি = [i + j জন্য i মধ্যে পরিসর(2) জন্য j মধ্যে পরিসর(2)]
ধরি ফিল্টার_সি = [x জন্য x মধ্যে পরিসর(6) যদি x % 2 == 0]

# চেষ্টা/ব্যতিক্রম/নাহলে
ধরি চেষ্টা_নাহলে = 0
চেষ্টা:
    চেষ্টা_নাহলে = পূর্ণসংখ্যা("7")
ব্যতিক্রম ValueError:
    চেষ্টা_নাহলে = -1
নাহলে:
    চেষ্টা_নাহলে += 1

# Exception chaining
ধরি শৃঙ্খলিত = মিথ্যা
চেষ্টা:
    চেষ্টা:
        তোলো ValueError("v")
    ব্যতিক্রম ValueError হিসাবে ve:
        তোলো RuntimeError("r") থেকে ve
ব্যতিক্রম RuntimeError:
    শৃঙ্খলিত = সত্য

# Multiple ব্যতিক্রম handlers
ধরি বহু_ব্যতিক্রম = 0
চেষ্টা:
    তোলো TypeError("t")
ব্যতিক্রম ValueError:
    বহু_ব্যতিক্রম = 1
ব্যতিক্রম TypeError:
    বহু_ব্যতিক্রম = 2

# Match/ক্ষেত্র সাথে পূর্বনির্ধারিত
ধরি ম্যাচ_মান = 2
ধরি ম্যাচ_ফল = "other"
মিলাও ম্যাচ_মান:
    ক্ষেত্র 1:
        ম্যাচ_ফল = "one"
    ক্ষেত্র 2:
        ম্যাচ_ফল = "two"
    পূর্বনির্ধারিত:
        ম্যাচ_ফল = "পূর্বনির্ধারিত"

# Decorator
সংজ্ঞা দ্বিগুণকারী(func):
    সংজ্ঞা মোড়ক(*আর্গস, **নামযুক্ত_আর্গস):
        ফেরত func(*আর্গস, **নামযুক্ত_আর্গস) * 2
    ফেরত মোড়ক

@দ্বিগুণকারী
সংজ্ঞা দশ():
    ফেরত 10

ধরি সাজ_ফল = দশ()

# Multiple inheritance, static/শ্রেণি methods, property
শ্রেণি মিশ্রণ:
    সংজ্ঞা মেশাও(self):
        ফেরত 1

শ্রেণি ভিত্তি_দুই:
    সংজ্ঞা __init__(self, start):
        self.value = start

শ্রেণি সমন্বিত(ভিত্তি_দুই, মিশ্রণ):
    @staticmethod
    সংজ্ঞা লেবেল():
        ফেরত "combined"
    @classmethod
    সংজ্ঞা নির্মাণ(cls, v):
        ফেরত cls(v)
    @property
    সংজ্ঞা দ্বিগুণ(self):
        ফেরত self.value * 2

ধরি সমন্বিত_বস্তু = সমন্বিত.নির্মাণ(3)
ধরি গুণ = সমন্বিত_বস্তু.দ্বিগুণ

# Docstring
সংজ্ঞা ডকসহ():
    """Has a docstring."""
    ফেরত সত্য

ছাপাও(হেক্স_সংখ্যা, অক্ট_সংখ্যা, বাইনারি_সংখ্যা, বৈজ্ঞানিক_সংখ্যা)
ছাপাও(বর্ধিত, বিট_এবং, বিট_অথবা, বিট_এক্স, বিট_বাম, বিট_ডান)
ছাপাও(শৃঙ্খল_ক, শৃঙ্খল_খ, শৃঙ্খল_গ)
ছাপাও(টাইপিত, টীকাযুক্ত(3, 1.5), ত্রিমুখী)
ছাপাও(বহু_ফল, বর্গ(5))
ছাপাও(তালিকা_সি, অভিধান_সি, জেনারেটর_সি)
ছাপাও(নেস্টেড_সি, ফিল্টার_সি)
ছাপাও(চেষ্টা_নাহলে, শৃঙ্খলিত, বহু_ব্যতিক্রম)
ছাপাও(ম্যাচ_ফল, সাজ_ফল, গুণ)
ছাপাও(ডকসহ())

# বিট-ওয়াইজ বর্ধিত নিয়োগ এবং ঘাত (v0.6.0)
ধরি বিট_চলক = 0b1111
বিট_চলক &= 0b1010
বিট_চলক |= 0b0100
বিট_চলক ^= 0b0011
বিট_চলক <<= 1
বিট_চলক >>= 2
ধরি ঘাত_বর্ধিত = 2
ঘাত_বর্ধিত **= 4

# বাইটস লিটারেল (v0.6.0)
ধরি বাইট_তথ্য = b"hello"
ধরি বাইট_দৈর্ঘ্য = দৈর্ঘ্য(বাইট_তথ্য)

# স্ট্রিং সংযোজন, সূচীকরণ এবং কাটা (v0.6.0)
ধরি স্ট্রিং_ক = "hello"
ধরি স্ট্রিং_খ = " world"
ধরি সংযুক্ত_স্ট্রিং = স্ট্রিং_ক + স্ট্রিং_খ
ধরি স্ট্রিং_সূচক = স্ট্রিং_ক[1]
ধরি স্ট্রিং_কাটা = স্ট্রিং_ক[1:3]

# টাপল লিটারেল (v0.6.0)
ধরি টাপল_বা = (10, 20, 30)
ধরি টাপল_উপাদান_বা = টাপল_বা[1]

# তালিকা চলকে for লুপ এবং তালিকা বোধ (v0.6.0)
ধরি পুনরাবৃত্তি_তালিকা = [10, 20, 30]
ধরি পুনরাবৃত্তি_যোগ = 0
জন্য পুনরাবৃত্তি_মান মধ্যে পুনরাবৃত্তি_তালিকা:
    পুনরাবৃত্তি_যোগ = পুনরাবৃত্তি_যোগ + পুনরাবৃত্তি_মান

ধরি দ্বিগুণ_উৎস = [1, 2, 3, 4]
ধরি দ্বিগুণ_তালিকা = [v * 2 জন্য v মধ্যে দ্বিগুণ_উৎস]

# বিস্তারিত মিলান: স্ট্রিং, কিছুনা, সংখ্যা এবং টাপল (v0.6.0)
ধরি স্ট্রিং_ম = "hello"
ধরি ফলাফল_স্ট্রিং_ম = "কিছু_নেই"
মিলাও স্ট্রিং_ম:
    ক্ষেত্র "hello":
        ফলাফল_স্ট্রিং_ম = "hi"
    ক্ষেত্র "bye":
        ফলাফল_স্ট্রিং_ম = "goodbye"
    পূর্বনির্ধারিত:
        ফলাফল_স্ট্রিং_ম = "unknown"

ধরি শূন্য_মান = কিছুনা
ধরি ফলাফল_শূন্য = "সংজ্ঞায়িত"
মিলাও শূন্য_মান:
    ক্ষেত্র কিছুনা:
        ফলাফল_শূন্য = "null"
    পূর্বনির্ধারিত:
        ফলাফল_শূন্য = "other"

ধরি সংখ্যা_ম = 42
ধরি ফলাফল_সংখ্যা_ম = 0
মিলাও সংখ্যা_ম:
    ক্ষেত্র 42:
        ফলাফল_সংখ্যা_ম = সংখ্যা_ম
    পূর্বনির্ধারিত:
        ফলাফল_সংখ্যা_ম = 0

ধরি টাপল_ম = (1, 2)
ধরি ফলাফল_টাপল_ম = "no"
মিলাও টাপল_ম:
    ক্ষেত্র (1, 2):
        ফলাফল_টাপল_ম = "yes"
    পূর্বনির্ধারিত:
        ফলাফল_টাপল_ম = "no"

# async def, await, async for, async with (v0.6.0)
asink সংজ্ঞা দ্বিগুণ_async(n):
    opekkha asyncio.sleep(0)
    ফেরত n * 2

asink সংজ্ঞা gen_async_bn():
    জন্য v মধ্যে range(3):
        উৎপন্ন v

asink সংজ্ঞা কাজ_async_জন্য():
    ধরি মোট_async = 0
    asink জন্য av মধ্যে gen_async_bn():
        মোট_async = মোট_async + av
    ফেরত মোট_async

শ্রেণি প্রসঙ্গ_Async_Bn:
    asink সংজ্ঞা __aenter__(self):
        ফেরত 5
    asink সংজ্ঞা __aexit__(self, exc_type, exc, tb):
        ফেরত মিথ্যা

asink সংজ্ঞা কাজ_async_সাথে():
    asink সাথে প্রসঙ্গ_Async_Bn() হিসাবে মূল্য:
        ফেরত মূল্য

ধরি async_ফলাফল = asyncio.run(দ্বিগুণ_async(5))
ধরি async_জন্য_ফলাফল = asyncio.run(কাজ_async_জন্য())
ধরি async_সাথে_ফলাফল = asyncio.run(কাজ_async_সাথে())

ছাপাও(বিট_চলক, ঘাত_বর্ধিত)
ছাপাও(বাইট_দৈর্ঘ্য)
ছাপাও(সংযুক্ত_স্ট্রিং, স্ট্রিং_সূচক, স্ট্রিং_কাটা)
ছাপাও(টাপল_উপাদান_বা, পুনরাবৃত্তি_যোগ)
ছাপাও(দ্বিগুণ_তালিকা)
ছাপাও(ফলাফল_স্ট্রিং_ম, ফলাফল_শূন্য, ফলাফল_সংখ্যা_ম, ফলাফল_টাপল_ম)
ছাপাও(async_ফলাফল, async_জন্য_ফলাফল, async_সাথে_ফলাফল)

