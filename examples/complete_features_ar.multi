# قناة للاتصال بين المهام
ليكن قناة_اتصال = قناة()
طباعة("تم إنشاء القناة بنجاح")

ليكن قناة_محدودة = قناة(capacity=10)
طباعة("تم إنشاء قناة محدودة")

# Async Concurrency Keywords (v0.8.0) - SPAWN, CHANNEL, SEND, RECEIVE
ليكن spawn_channel = قناة()

async دالة spawn_test_async():
    async دالة task_worker(value):
        await asyncio.sleep(0)
        إرجاع value * 2

    ليكن spawn_task = أطلق(task_worker(5))
    إرجاع "spawn task created"

ليكن spawn_result = asyncio.run(spawn_test_async())
طباعة("Async concurrency keywords validated:", spawn_result)

