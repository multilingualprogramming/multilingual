# كلمات مفاتيح التزامن (v0.7.0) - متوازٍ، قناة، إطلاق
دالة أضف_أرقام(x, y):
    إرجاع x + y

دالة اضرب_أرقام(x, y):
    إرجاع x * y

ليكن par_a, par_b = متوازٍ [
    أضف_أرقام(5, 3),
    اضرب_أرقام(4, 2)
]
طباعة("نتائج متوازٍ:", par_a, par_b)

# متوازٍ متداخل
