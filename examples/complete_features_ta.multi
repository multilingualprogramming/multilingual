# பணிகளுக்கு இடையில் தொடர்புக்கான சேனல்
இருக்கட்டும் சேனல்_தொடர்பு = சேனல்()
அச்சிடு("சேனல் வெற்றிகரமாக உருவாக்கப்பட்டது")

இருக்கட்டும் சேனல்_கட்டுப்படுத்தப்பட்ட = சேனல்(capacity=10)
அச்சிடு("கட்டுப்படுத்தப்பட்ட சேனல் உருவாக்கப்பட்டது")

# Async Concurrency Keywords (v0.8.0) - SPAWN, CHANNEL, SEND, RECEIVE
இருக்கட்டும் spawn_channel = சேனல்()

async வரையறு spawn_test_async():
    async வரையறு task_worker(value):
        kaththiru asyncio.sleep(0)
        திருப்பு value * 2

    இருக்கட்டும் spawn_task = தொடங்கு(task_worker(5))
    திருப்பு "spawn task created"

இருக்கட்டும் spawn_result = asyncio.run(spawn_test_async())
அச்சிடு("Async concurrency keywords validated:", spawn_result)

# Reactive UI Keywords (v0.8.0) - OBSERVE, ON_CHANGE
வரையறு test_reactive_ui() பயன்படுத்து ui:
    கவனி var counter_value = 0
    கவனி var status_text = "ready"

    மாற்றத்தில் counter_value.change:
        அச்சிடு("Counter value changed")

    மாற்றத்தில் status_text.change:
        அச்சிடு("Status changed")

    அச்சிடு("Reactive UI keywords validated")

test_reactive_ui()

# வரிசையாக பல செயற்கை நுண்ணறிவு அழைப்புகள்
