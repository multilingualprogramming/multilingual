# இரும நிலை அதிக ஒதுக்கீடு மற்றும் அடுக்கு (v0.6.0)
இருக்கட்டும் இரும_மாறி = 0b1111
இரும_மாறி &= 0b1010
இரும_மாறி |= 0b0100
இரும_மாறி ^= 0b0011
இரும_மாறி <<= 1
இரும_மாறி >>= 2
இருக்கட்டும் அடுக்கு_அதிகம் = 2
அடுக்கு_அதிகம் **= 4

# பைட்கள் எழுத்துரு (v0.6.0)
இருக்கட்டும் பைட்_தரவு = b"hello"
இருக்கட்டும் பைட்_நீளம் = நீளம்(பைட்_தரவு)

# சரம் இணைப்பு, குறியீடு மற்றும் வெட்டு (v0.6.0)
இருக்கட்டும் நூல்_அ = "hello"
இருக்கட்டும் நூல்_ஆ = " world"
இருக்கட்டும் சரம்_இணைப்பு = நூல்_அ + நூல்_ஆ
இருக்கட்டும் சரம்_குறியீடு = நூல்_அ[1]
இருக்கட்டும் சரம்_வெட்டு = நூல்_அ[1:3]

# உறுப்பு தொடர் எழுத்துரு (v0.6.0)
இருக்கட்டும் உறுப்பு_தொடர்_த = (10, 20, 30)
இருக்கட்டும் உறுப்பு_தொடர்_உறுப்பு_த = உறுப்பு_தொடர்_த[1]

# பட்டியல் மாறியில் for சுழற்சி மற்றும் பட்டியல் புரிதல் (v0.6.0)
இருக்கட்டும் மீண்டும்_பட்டியல் = [10, 20, 30]
இருக்கட்டும் மீண்டும்_கூட்டல் = 0
ஒவ்வொரு மீண்டும்_மதிப்பு இல் மீண்டும்_பட்டியல்:
    மீண்டும்_கூட்டல் = மீண்டும்_கூட்டல் + மீண்டும்_மதிப்பு

இருக்கட்டும் இரட்டை_மூலம் = [1, 2, 3, 4]
இருக்கட்டும் இரட்டை_பட்டியல் = [v * 2 ஒவ்வொரு v இல் இரட்டை_மூலம்]

# விரிவான பொருத்து: சரம், ஒன்றுமில்லை, எண் மற்றும் உறுப்பு தொடர் (v0.6.0)
இருக்கட்டும் சரம்_ம = "hello"
இருக்கட்டும் முடிவு_சரம்_ம = "எதுவுமில்லை"
பொருத்து சரம்_ம:
    நிலை "hello":
        முடிவு_சரம்_ம = "hi"
    நிலை "bye":
        முடிவு_சரம்_ம = "goodbye"
    இயல்பு:
        முடிவு_சரம்_ம = "unknown"

இருக்கட்டும் ஒன்றுமில்லை_மதிப்பு = ஒன்றுமில்லை
இருக்கட்டும் முடிவு_ஒன்றுமில்லை = "வரையறுக்கப்பட்ட"
பொருத்து ஒன்றுமில்லை_மதிப்பு:
    நிலை ஒன்றுமில்லை:
        முடிவு_ஒன்றுமில்லை = "null"
    இயல்பு:
        முடிவு_ஒன்றுமில்லை = "other"

இருக்கட்டும் எண்_ம = 42
இருக்கட்டும் முடிவு_எண்_ம = 0
பொருத்து எண்_ம:
    நிலை 42:
        முடிவு_எண்_ம = எண்_ம
    இயல்பு:
        முடிவு_எண்_ம = 0

இருக்கட்டும் உறுப்பு_தொடர்_ம = (1, 2)
இருக்கட்டும் முடிவு_உறுப்பு_தொடர்_ம = "no"
பொருத்து உறுப்பு_தொடர்_ம:
    நிலை (1, 2):
        முடிவு_உறுப்பு_தொடர்_ம = "yes"
    இயல்பு:
        முடிவு_உறுப்பு_தொடர்_ம = "no"

# async def, await, async for, async with (v0.6.0)
async வரையறு இரட்டை_async(n):
    kaththiru asyncio.sleep(0)
    திருப்பு n * 2

async வரையறு gen_async_ta():
    ஒவ்வொரு v இல் range(3):
        விளை v

async வரையறு பணி_async_ஒவ்வொரு():
    இருக்கட்டும் மொத்தம்_async = 0
    async ஒவ்வொரு av இல் gen_async_ta():
        மொத்தம்_async = மொத்தம்_async + av
    திருப்பு மொத்தம்_async

வகுப்பு சூழல்_Async_Ta:
    async வரையறு __aenter__(self):
        திருப்பு 5
    async வரையறு __aexit__(self, exc_type, exc, tb):
        திருப்பு பொய்

async வரையறு பணி_async_உடன்():
    async உடன் சூழல்_Async_Ta() ஆக மதிப்பு:
        திருப்பு மதிப்பு

இருக்கட்டும் async_முடிவு = asyncio.run(இரட்டை_async(5))
இருக்கட்டும் async_ஒவ்வொரு_முடிவு = asyncio.run(பணி_async_ஒவ்வொரு())
இருக்கட்டும் async_உடன்_முடிவு = asyncio.run(பணி_async_உடன்())

அச்சிடு(இரும_மாறி, அடுக்கு_அதிகம்)
அச்சிடு(பைட்_நீளம்)
அச்சிடு(சரம்_இணைப்பு, சரம்_குறியீடு, சரம்_வெட்டு)
அச்சிடு(உறுப்பு_தொடர்_உறுப்பு_த, மீண்டும்_கூட்டல்)
அச்சிடு(இரட்டை_பட்டியல்)
அச்சிடு(முடிவு_சரம்_ம, முடிவு_ஒன்றுமில்லை, முடிவு_எண்_ம, முடிவு_உறுப்பு_தொடர்_ம)
அச்சிடு(async_முடிவு, async_ஒவ்வொரு_முடிவு, async_உடன்_முடிவு)

# செயற்கை நுண்ணறிவு முக்கிய சொற்கள் (v0.7.0) - சோதனைகளில் MockProvider உடன் வேலை செய்கிறது
இருக்கட்டும் முடிவு_prompt = கேள் @default: "2 + 2 என்ன?"
அச்சிடு("கேள்:", முடிவு_prompt)

இருக்கட்டும் முடிவு_உருவாக்கு = உருவாக்கு @default: "எளிய JSON பொருளை உருவாக்கவும்"
அச்சிடு("உருவாக்கு:", முடிவு_உருவாக்கு)

இருக்கட்டும் முடிவு_பிரித்தெடு = பிரி @default: "கூறுகளை பிரித்தெடுக்கவும்: ஆப்பிள், வாழைப்பழம், ஆரஞ்சு"
அச்சிடு("பிரி:", முடிவு_பிரித்தெடு)

இருக்கட்டும் முடிவு_வகைப்படுத்து = வகைப்படுத்து @default: "இது அருமை!"
அச்சிடு("வகைப்படுத்து:", முடிவு_வகைப்படுத்து)

இருக்கட்டும் முடிவு_யோசனை = சிந்தி @default: "42 ஏன் முக்கியமானது?"
அச்சிடு("சிந்தி:", முடிவு_யோசனை)

இருக்கட்டும் முடிவு_ஸ்ட்ரீம் = ஓட்டம் @default: "ஒரு குறுகிய கதையை சொல்லுங்கள்"
இருக்கட்டும் உள்ளடக்கம்_ஸ்ட்ரீம் = ""
ஒவ்வொரு பகுதி_ஸ்ட்ரீம் இல் முடிவு_ஸ்ட்ரீம்:
    உள்ளடக்கம்_ஸ்ட்ரீம் = உள்ளடக்கம்_ஸ்ட்ரீம் + சரம்(பகுதி_ஸ்ட்ரீம்)
அச்சிடு("ஓட்டம்:", உள்ளடக்கம்_ஸ்ட்ரீம்)

இருக்கட்டும் முடிவு_திட்டம் = plan @default: "ஒரு கேக்கை எப்படி சுட்ட வேண்டும்"
அச்சிடு("PLAN:", முடிவு_திட்டம்)

இருக்கட்டும் முடிவு_உட்பொதிக்க = உட்பொதி @default: "இது ஒரு வாக்கியம்"
அச்சிடு("உட்பொதி பரிமாணங்கள்:", நீளம்(முடிவு_உட்பொதிக்க))

இருக்கட்டும் முடிவு_பரிவர்த்தனை = transcribe @default: "கற்பனை_ஆடியோ_தகவல்"
அச்சிடு("TRANSCRIBE:", முடிவு_பரிவர்த்தனை)

# ஒத்திசைவு முக்கிய சொற்கள் (v0.7.0) - இணையாக, சேனல், தொடங்கு
வரையறு எண்களைச்_சேர்க்கவும்(x, y):
    திருப்பு x + y

வரையறு எண்களைப்_பெருக்கவும்(x, y):
    திருப்பு x * y

இருக்கட்டும் par_a, par_b = இணையாக [
